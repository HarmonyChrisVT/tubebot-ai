# TubeBot AI - Environment Variables

# OpenAI (required for scripts, thumbnails, SEO)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# YouTube Data API v3 — OAuth2 credentials JSON (single-line)
# Generate via: https://console.cloud.google.com/
YOUTUBE_CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxx
YOUTUBE_SCHEDULE_HOURS=24

# Pexels API (free — stock footage for video assembly via FFmpeg)
# Sign up for a free key at https://www.pexels.com/api/
# Free tier: 200 requests/hour, 20 000 requests/month — no credit card needed.
PEXELS_API_KEY=

# Niche topics (comma-separated, optional)
TREND_NICHES=Medicare benefits,senior health tips,retirement planning,Social Security

# System
DATABASE_PATH=/app/data/tubebot.db
PORT=8080
